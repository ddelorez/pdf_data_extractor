# PDF Data Extractor - Environment Configuration
# Copy this file to .env and adjust settings for your environment

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here-min-32-chars-recommended

# File Upload Configuration
MAX_UPLOAD_SIZE=104857600  # 100 MB in bytes
UPLOAD_FOLDER=/app/uploads
TEMPLATE_FOLDER=/app/templates
OUTPUT_FOLDER=/app/outputs

# Logging
LOG_LEVEL=INFO

# Server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# CORS Configuration. '*' allows any origin (convenient but permissive).
# For production set this to your deployed origin(s), e.g. https://pdf.example.com
# (the SPA and API are same-origin behind nginx, so this can be tightened — see issue #1).
CORS_ORIGINS=*

# PDF Processing
DEFAULT_TIMEOUT=30
MAX_BATCH_FILES=50
