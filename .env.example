# PDF Data Extractor - Environment Configuration
# Copy this file to .env and adjust settings for your environment

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
# REQUIRED when FLASK_ENV=production. The app refuses to boot on a missing or
# placeholder key (issue #1.6). Generate a strong value:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-generated-secret

# File Upload Configuration
MAX_UPLOAD_SIZE=104857600  # 100 MB in bytes
UPLOAD_FOLDER=/app/uploads
TEMPLATE_FOLDER=/app/templates
OUTPUT_FOLDER=/app/outputs

# Logging
LOG_LEVEL=INFO

# Server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# CORS is owned by nginx (frontend/nginx.conf), not Flask (issue #1.9), so this
# variable is no longer read by the backend. Adjust the Access-Control-* headers
# in nginx.conf to restrict origins for production.
# CORS_ORIGINS=*

# PDF Processing
DEFAULT_TIMEOUT=30
MAX_BATCH_FILES=50
