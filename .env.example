# PDF Parser Project - Phase 2 Environment Configuration
# Copy this file to .env and adjust settings for your environment

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here-min-32-chars-recommended

# File Upload Configuration
MAX_UPLOAD_SIZE=104857600  # 100 MB in bytes
UPLOAD_FOLDER=/app/uploads
TEMPLATE_FOLDER=/app/templates
OUTPUT_FOLDER=/app/outputs

# Logging
LOG_LEVEL=INFO

# Server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# CORS Configuration (for React frontend in Phase 3)
CORS_ORIGINS=*

# PDF Processing
DEFAULT_TIMEOUT=30
MAX_BATCH_FILES=50
